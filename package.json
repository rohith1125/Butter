{
  "name": "butter-bear",
  "displayName": "Butter Bear",
  "description": "10 warm golden themes (Dark, Light, Soft, Midnight, Mocha, Storm, Rose, Forest, AMOLED, HC) + a growing bear companion with prestige system.",
  "version": "3.0.0",
  "publisher": "butterdev",
  "license": "MIT",
  "icon": "butter.png",
  "galleryBanner": {
    "color": "#1e1b12",
    "theme": "dark"
  },
  "homepage": "https://github.com/rohith1125/butter-bear",
  "repository": {
    "type": "git",
    "url": "https://github.com/rohith1125/butter-bear.git"
  },
  "bugs": {
    "url": "https://github.com/rohith1125/butter-bear/issues"
  },
  "keywords": [
    "theme", "color theme", "warm", "golden", "amber", "cozy",
    "dark theme", "light theme", "butter", "gruvbox", "rose pine",
    "catppuccin", "night owl", "midnight", "mocha", "storm", "rose",
    "forest", "amoled", "high contrast", "oled", "darcula", "prestige",
    "tokyo night", "bear", "companion", "gamification"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "themes": [
      { "label": "Butter Dark",     "uiTheme": "vs-dark",   "path": "./themes/butter-dark.json" },
      { "label": "Butter Light",    "uiTheme": "vs",         "path": "./themes/butter-light.json" },
      { "label": "Butter Soft",     "uiTheme": "vs-dark",   "path": "./themes/butter-soft.json" },
      { "label": "Butter Midnight", "uiTheme": "vs-dark",   "path": "./themes/butter-midnight.json" },
      { "label": "Butter Mocha",    "uiTheme": "vs-dark",   "path": "./themes/butter-mocha.json" },
      { "label": "Butter Storm",    "uiTheme": "vs-dark",   "path": "./themes/butter-storm.json" },
      { "label": "Butter Rose",     "uiTheme": "vs-dark",   "path": "./themes/butter-rose.json" },
      { "label": "Butter Forest",   "uiTheme": "vs-dark",   "path": "./themes/butter-forest.json" },
      { "label": "Butter AMOLED",   "uiTheme": "vs-dark",   "path": "./themes/butter-amoled.json" },
      { "label": "Butter HC",       "uiTheme": "hc-black",  "path": "./themes/butter-hc.json" }
    ],
    "commands": [
      {
        "command": "butter.feedBear",
        "title": "Feed the Bear 🍯",
        "category": "Butter"
      },
      {
        "command": "butter.bearStats",
        "title": "Bear Stats",
        "category": "Butter"
      },
      {
        "command": "butter.switchTheme",
        "title": "Switch Butter Theme",
        "category": "Butter"
      },
      {
        "command": "butter.toggleCompanion",
        "title": "Toggle Butter Bear",
        "category": "Butter"
      },
      {
        "command": "butter.companionMood",
        "title": "Show Bear's Mood",
        "category": "Butter"
      }
    ],
    "configuration": {
      "title": "Butter",
      "properties": {
        "butter.companion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Butter Bear companion in the status bar."
        },
        "butter.companion.activityTimeout": {
          "type": "number",
          "default": 30000,
          "description": "Milliseconds of inactivity before Butter Bear enters the resting state."
        },
        "butter.companion.morningGreeting": {
          "type": "boolean",
          "default": true,
          "description": "Show a morning greeting notification on the first activation of each day."
        },
        "butter.companion.showMessages": {
          "type": "boolean",
          "default": true,
          "description": "Show state-change notifications from Butter Bear."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
