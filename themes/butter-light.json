  "semanticTokenColors": {
    "function": "#6a5000",
    "method": "#6a5000",
    "variable": "#2a2010",
    "parameter": "#4a3820",
    "property": "#6a4820",
    "class": "#804838",
    "interface": "#804838",
    "type": "#804838",
    "typeParameter": "#804838",
    "enum": "#7a6000",
    "enumMember": "#7a6000",
    "namespace": "#6a6050",
    "module": "#6a6050",
    "string": "#8a5820",
    "number": "#7a6000",
    "keyword": "#804020",
    "modifier": "#804020",
    "comment": {
      "foreground": "#8a7850",
      "fontStyle": "italic"
    },
    "decorator": "#7a4820",
    "macro": "#7a6000"
  },

  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#8a7850", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#8a5820" }
    },
    {
      "name": "String escapes",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#6a5000" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#804020" }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#6a5000" }
    },
    {
      "name": "Classes and types",
      "scope": ["entity.name.type", "entity.name.class", "support.class"],
      "settings": { "foreground": "#804838" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#2a2010" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#4a3820" }
    },
    {
      "name": "Properties",
      "scope": ["variable.other.property", "meta.object-literal.key", "support.type.property-name"],
      "settings": { "foreground": "#6a4820" }
    },
    {
      "name": "Constants",
      "scope": ["constant", "variable.other.constant"],
      "settings": { "foreground": "#7a5800" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric", "constant.language.boolean", "constant.language.null"],
      "settings": { "foreground": "#7a6000" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#804020" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#8a7850" }
    },
    {
      "name": "HTML tags",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#804020" }
    },
    {
      "name": "HTML attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#7a4820" }
    },
    {
      "name": "Decorators",
      "scope": ["entity.name.decorator", "meta.decorator"],
      "settings": { "foreground": "#7a4820" }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading"],
      "settings": { "foreground": "#7a5010", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#6a5000", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#8a5820", "fontStyle": "italic" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw.string.markdown", "markup.fenced_code.block.markdown"],
      "settings": { "foreground": "#8a5820" }
    },
    {
      "name": "Markdown link",
      "scope": ["markup.underline.link.markdown"],
      "settings": { "foreground": "#7a5010", "fontStyle": "underline" }
    },
    {
      "name": "CSS selectors",
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#804020" }
    },
    {
      "name": "CSS properties",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#6a4820" }
    },
    {
      "name": "CSS values",
      "scope": ["support.constant.property-value.css", "constant.numeric.css"],
      "settings": { "foreground": "#8a5820" }
    },
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#6a4820" }
    },
    {
      "name": "YAML keys",
      "scope": ["entity.name.tag.yaml"],
      "settings": { "foreground": "#6a4820" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#8a2020", "fontStyle": "underline" }
    },
    {
      "name": "Diff inserted",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#4a8830" }
    },
    {
      "name": "Diff deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#8a2020" }
    },
    {
      "name": "Support types",
      "scope": ["support.type", "support.type.primitive", "support.type.builtin"],
      "settings": { "foreground": "#804838" }
    },
    {
      "name": "Language variables",
      "scope": ["variable.language", "variable.language.this", "variable.language.super"],
      "settings": { "foreground": "#804020" }
    }
  ]
}
