  "semanticTokenColors": {
    "function": "#b09840",
    "method": "#b09840",
    "variable": "#a8a088",
    "parameter": "#989080",
    "property": "#908860",
    "class": "#a87848",
    "interface": "#a87848",
    "type": "#a87848",
    "typeParameter": "#a87848",
    "enum": "#b08038",
    "enumMember": "#b08038",
    "namespace": "#808070",
    "module": "#808070",
    "string": "#a08030",
    "number": "#b09830",
    "keyword": "#906028",
    "modifier": "#906028",
    "comment": {
      "foreground": "#504840",
      "fontStyle": "italic"
    },
    "decorator": "#906030",
    "macro": "#b08038"
  },

  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#504840", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#a08030" }
    },
    {
      "name": "String escapes",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#b09840" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#906028" }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#b09840" }
    },
    {
      "name": "Classes and types",
      "scope": ["entity.name.type", "entity.name.class", "support.class"],
      "settings": { "foreground": "#a87848" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#a8a088" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#989080" }
    },
    {
      "name": "Properties",
      "scope": ["variable.other.property", "meta.object-literal.key", "support.type.property-name"],
      "settings": { "foreground": "#908860" }
    },
    {
      "name": "Constants",
      "scope": ["constant", "variable.other.constant"],
      "settings": { "foreground": "#b08038" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric", "constant.language.boolean", "constant.language.null"],
      "settings": { "foreground": "#b09830" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#987040" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "punctuation.separator"],
      "settings": { "foreground": "#605848" }
    },
    {
      "name": "HTML tags",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#906038" }
    },
    {
      "name": "HTML attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#887840" }
    },
    {
      "name": "Decorators",
      "scope": ["entity.name.decorator", "meta.decorator"],
      "settings": { "foreground": "#906030" }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading"],
      "settings": { "foreground": "#9a7c1e", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#b09840", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#a08030", "fontStyle": "italic" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw.string.markdown", "markup.fenced_code.block.markdown"],
      "settings": { "foreground": "#a08030" }
    },
    {
      "name": "CSS selectors",
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css"],
      "settings": { "foreground": "#906038" }
    },
    {
      "name": "CSS properties",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#908860" }
    },
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#908860" }
    },
    {
      "name": "YAML keys",
      "scope": ["entity.name.tag.yaml"],
      "settings": { "foreground": "#908860" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#9a4040", "fontStyle": "underline" }
    },
    {
      "name": "Diff inserted",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#5a8840" }
    },
    {
      "name": "Diff deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#9a4040" }
    },
    {
      "name": "Support types",
      "scope": ["support.type", "support.type.builtin"],
      "settings": { "foreground": "#a87848" }
    },
    {
      "name": "Language variables",
      "scope": ["variable.language", "variable.language.this"],
      "settings": { "foreground": "#906028" }
    }
  ]
}
